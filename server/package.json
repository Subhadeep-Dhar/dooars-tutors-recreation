        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "express-rate-limit": "^7.3.1",
        "express-validator": "^7.1.0",
        "helmet": "^7.1.0",
        "ioredis": "^5.4.1",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.4.4",
